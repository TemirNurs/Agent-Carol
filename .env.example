# Carol environment variables.
# Copy this file to `.env` and fill in real values. .env is gitignored.
#
# IMPORTANT: never commit .env. The .env.example shipped with the repo
# only contains keys, never actual secrets.

# Gmail (estimates@carolinacommercialfinishes.com)
# App password from Google Account → Security → 2-Step Verification → App passwords
GMAIL_USER=estimates@carolinacommercialfinishes.com
GMAIL_APP_PASSWORD=

# Telegram bot (BotFather token)
TELEGRAM_BOT_TOKEN=
USER_TELEGRAM_CHAT_ID=

# OpenAI / Anthropic / Gemini API keys (for LLM features)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Hyperscale Wiring forward target
HYPERSCALE_EMAIL=cs@hyperscalewiring.com

# Google Sheets — service account JSON path (not the contents)
GOOGLE_SERVICE_ACCOUNT_PATH=data/config/google_service_account.json

# OpenClaw gateway (for hallucination sentry to ask Carol)
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=
