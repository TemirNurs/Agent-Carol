# Carol environment variables.
# Copy this file to `.env` and fill in real values. .env is gitignored.
#
# IMPORTANT: never commit .env. The .env.example shipped with the repo
# only contains keys, never actual secrets.

# Gmail (estimates@carolinacommercialfinishes.com)
# App password from Google Account → Security → 2-Step Verification → App passwords
GMAIL_USER=estimates@carolinacommercialfinishes.com
GMAIL_APP_PASSWORD=

# Telegram bot (BotFather token)
TELEGRAM_BOT_TOKEN=
USER_TELEGRAM_CHAT_ID=

# OpenAI / Anthropic / Gemini API keys (for LLM features)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Hyperscale Wiring forward target
HYPERSCALE_EMAIL=cs@hyperscalewiring.com

# Google Sheets — service account JSON path (not the contents)
GOOGLE_SERVICE_ACCOUNT_PATH=data/config/google_service_account.json

# OpenClaw gateway (for hallucination sentry to ask Carol)
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=

# --- Team / owner identity (kept out of tracked source; code reads these via _lib/company.py) ---
# Comma-separated internal CC list for every external send (company address + team).
CCF_INTERNAL_CC=cs@yourcompany.com
# Comma-separated substrings that mark mail as your own/internal traffic.
CCF_OWN_DOMAINS=yourcompany
# Telegram "id:name" pairs (comma-separated) for team-message attribution.
TEAM_TELEGRAM_IDS=
# Owner's personal contact (used by alerting / "who am I" checks).
OWNER_PERSONAL_EMAIL=
OWNER_PHONE=
# Any owner/team alias addresses that should count as "us" in audits.
OWNER_ALIAS_EMAILS=
# BuildingConnected / portal login identifier (never a password — just the username).
BC_LOGIN_EMAIL=

# --- Google resources (Sheets/Drive ids; never commit the real ids) ---
CRM_SHEET_ID=
CRM_SHEET_NAME=
CRM_SHEET_XLSX_ID=
GDRIVE_FOLDER_ID=

# Comma-separated team first names (hallucination-sentry claim detection)
TEAM_FIRST_NAMES=

# Comma-separated team name tokens (full names, first names, last names) for the internal-GC junk guard
TEAM_NAME_TOKENS=
