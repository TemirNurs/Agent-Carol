    "bid_formula": [
      "STEP 1: LABOR COST = Total SF \u00d7 (1 \u00f7 Production Rate SF/hr) \u00d7 Burdened Hourly Rate",
      "STEP 2: MATERIAL COST = Total SF \u00f7 Coverage (SF/gal) \u00d7 Price per Gallon \u00d7 Number of Coats",
      "STEP 3: DIRECT COST = Labor + Materials + Equipment Rental + Travel/Mobilization",
      "STEP 4: OVERHEAD = Direct Cost \u00d7 Overhead % (target 10-15%)",
      "STEP 5: BID PRICE = (Direct Cost + Overhead) \u00d7 (1 + Markup %)   \u2190 This is our number",
